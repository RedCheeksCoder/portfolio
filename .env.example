# Copy this file to .env for local `vercel dev` testing.
# Real values go into Vercel Project Settings -> Environment Variables in production.
# NEVER commit a file containing real values.

# GHL Private Integration (Settings -> Private Integrations in the GHL sub-account
# currently running the booking widget - contacts read/write + calendar/appointment
# scopes). GHL is the only external system this backend talks to as of 2026-07-18 -
# Google Calendar was removed since GHL's own calendar is Bryan's full schedule.
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=

# Canonical timezone the booking backend computes/display availability in (IANA name).
BOOKING_TIMEZONE=Asia/Manila
