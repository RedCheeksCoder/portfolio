# Copy this file to .env for local `vercel dev` testing.
# Real values go into Vercel Project Settings -> Environment Variables in production.
# NEVER commit a file containing real values.

# Google Cloud service-account credentials (see CLAUDE.md "Booking Backend" section
# for the full setup checklist: create project, enable Calendar API, create service
# account, download JSON key, share Bryan's calendar with the service account email).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key value from the downloaded JSON as-is (it contains literal \n
# sequences - the code converts them to real newlines automatically).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# GHL Private Integration (Settings -> Private Integrations in the GHL sub-account
# currently running the booking widget - contacts + calendar/appointment scopes).
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_LOCATION_ID=
GHL_CALENDAR_ID=

# Canonical timezone the booking backend computes availability in (IANA name).
BOOKING_TIMEZONE=Asia/Manila
